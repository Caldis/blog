---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("thoughts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"thoughts">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const layout = post.data.heroLayout ?? "stacked";
const hasImage = !!post.data.image;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Layout title={post.data.title}>
  <article data-layout={layout}>
    {hasImage && layout === "spread" && (
      <header class="hero hero-spread">
        <figure>
          <img src={post.data.image} alt={post.data.imageAlt ?? ""} />
        </figure>
        <div class="meta">
          <time datetime={post.data.date.toISOString()}>
            {fmt(post.data.date)}
          </time>
          <h1>{post.data.title}</h1>
          {post.data.subtitle && <p class="subtitle">{post.data.subtitle}</p>}
        </div>
      </header>
    )}

    {layout !== "spread" && (
      <Fragment>
        {hasImage && (
          <figure class="hero hero-stacked">
            <img src={post.data.image} alt={post.data.imageAlt ?? ""} />
          </figure>
        )}
        <header class="meta meta-stacked">
          <time datetime={post.data.date.toISOString()}>
            {fmt(post.data.date)}
          </time>
          <h1>{post.data.title}</h1>
          {post.data.subtitle && <p class="subtitle">{post.data.subtitle}</p>}
        </header>
      </Fragment>
    )}

    <hr class="hero-divider" />

    <div class="prose">
      <Content />
    </div>
  </article>
  <Footer />
</Layout>

<style>
  article {
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  /* Breakout technique: these blocks escape the 42rem container and
     center themselves in the viewport. */
  .hero-stacked,
  .hero-spread {
    width: min(65rem, calc(100vw - 2.5rem));
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  .hero-spread {
    width: min(62rem, calc(100vw - 2.5rem));
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: clamp(1.5rem, 3.5vw, 3rem);
    align-items: end;
  }

  @media (max-width: 46rem) {
    .hero-spread {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }

  .hero figure {
    margin: 0;
  }

  .hero img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 30px;
    box-shadow: 0 1px 2px rgba(27, 25, 23, 0.05),
      0 10px 28px -10px rgba(27, 25, 23, 0.22);
  }

  .hero-spread .meta {
    padding-bottom: 0.35rem;
  }

  .hero-spread .meta h1 {
    font-size: clamp(1.625rem, 3.2vw, 2.125rem);
  }

  /* Meta (shared) — also the hero morph target from a thoughts list card.
     The list's <a class="entry"> expands into this block via the `hero`
     view-transition group. */
  .meta {
    display: grid;
    gap: 0.625rem;
    view-transition-name: hero;
  }

  .meta time {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--ink-faint);
    font-feature-settings: "tnum";
  }

  /* Typography aligns with the list card's .entry h2 so the hero morph's
     content crossfade (220ms) doesn't read as a color/weight jump. The
     delta that remains is purely size — which is exactly the "this grew
     into its detail form" reading we want. */
  .meta h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 4vw, 2.5rem);
    font-weight: 460;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--ink);
    font-variation-settings: "opsz" 36;
  }

  /* Subtitle aligns with list summary: same family (sans), same weight,
     same color, same style (non-italic), same line-height. Size allowed
     to nudge up. */
  .meta .subtitle {
    font-family: var(--font-sans);
    font-size: clamp(0.9375rem, 1.4vw, 1.0625rem);
    font-weight: 400;
    line-height: 1.65;
    letter-spacing: 0;
    color: var(--ink-soft);
    font-style: normal;
    max-width: 36rem;
    margin-top: 0.5rem;
  }

  .meta-stacked {
    margin-top: 3rem;
  }

  /* Divider between hero block and body */
  .hero-divider {
    border: none;
    border-top: 1px solid var(--rule);
    margin: clamp(0.75rem, 2vw, 1.5rem) 0 0;
  }

  /* Prose */
  .prose {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.85;
    color: var(--ink);
  }

  .prose :global(p) {
    margin-bottom: 1.25em;
  }

  .prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 480;
    line-height: 1.3;
    letter-spacing: -0.012em;
    margin: 2.25em 0 0.9em;
    font-variation-settings: "opsz" 24;
  }

  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 1.75em 0 0.75em;
    font-variation-settings: "opsz" 18;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(
      in oklab,
      currentColor 30%,
      transparent
    );
    text-underline-offset: 0.22em;
    text-decoration-thickness: 1px;
    transition: color 180ms ease, text-decoration-color 180ms ease;
  }

  .prose :global(a:hover) {
    color: var(--accent-strong);
    text-decoration-color: currentColor;
  }

  .prose :global(strong) {
    font-weight: 580;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(blockquote) {
    margin: 1.5em 0;
    padding-left: 1.25em;
    border-left: 2px solid var(--rule);
    color: var(--ink-soft);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25em;
    padding-left: 1.5em;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
  }

  .prose :global(hr) {
    margin: 2.5em auto;
    width: 3.5rem;
    border: none;
    border-top: 1px solid var(--rule);
  }

  .prose :global(code) {
    font-family: ui-monospace, "SF Mono", Menlo, Monaco, Consolas,
      "Liberation Mono", monospace;
    font-size: 0.88em;
    background: color-mix(in oklab, var(--ink-faint) 18%, transparent);
    padding: 0.12em 0.35em;
    border-radius: 2px;
  }

  .prose :global(pre) {
    margin: 1.5em 0;
    padding: 1em 1.25em;
    background: color-mix(in oklab, var(--ink) 6%, transparent);
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .prose :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5em 0;
    border-radius: 4px;
  }
</style>
