---
import LogoMark from "../../brand/LogoMark.astro";
---

<section class="about">
  <div class="mark-hero">
    <canvas
      class="mark-canvas"
      data-mark-canvas
      aria-hidden="true"></canvas>
    <!-- SSR fallback of the same logo. JS replaces this with the
         interactive dot-matrix canvas on mount. Keeps the page
         identifiable with JS disabled and on the pre-hydration paint. -->
    <LogoMark
      class="mark-fallback"
      gradientId="caldis-mark-hero"
    />
  </div>

  <h1>Caldis</h1>
  <p>
    Writing sometimes, building often. These pages collect whatever felt
    worth keeping.
  </p>
  <ul class="links" role="list">
    <li>
      <a
        href="https://x.com/Caldis_Chen"
        target="_blank"
        rel="noopener"
        aria-label="X (formerly Twitter)"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </a>
    </li>
    <li>
      <a
        href="https://github.com/Caldis"
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
      </a>
    </li>
    <li>
      <a href="mailto:mail@caldis.me" aria-label="Email">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z" />
          <path d="M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z" />
        </svg>
      </a>
    </li>
  </ul>
</section>

<script>
  /*
   * Interactive dot-matrix mark.
   *
   * Rasterises the same square+diagonal geometry as the favicon onto
   * an off-screen canvas, samples the alpha channel on a grid to get
   * ~50 dot positions, then renders them on the visible canvas with
   * a mouse-repel + spring-back physics loop.
   *
   * Performance:
   *   • Dots live in CSS-px coordinates; the visible canvas uses dpr
   *     scaling only at draw time.
   *   • RAF loop auto-pauses once all dots have settled back to base
   *     AND the pointer is no longer inside the canvas. mousemove
   *     restarts it.
   *   • Resize uses ResizeObserver and re-samples only on real size
   *     change.
   *   • Honors prefers-reduced-motion: draws the static dot pattern
   *     once and exits the physics loop entirely.
   */

  // All geometry comes from the shared brand source. Edit there, not here.
  import {
    MARK_VIEWBOX,
    FRAME,
    DIAGONAL,
    DIAGONAL_FADE,
  } from "../../brand/geometry";

  type Dot = {
    bx: number;
    by: number;
    x: number;
    y: number;
    /** 0..1 painted alpha, determined at sample time by source
     *  geometry (frame dots are opaque; diagonal dots fade bottom→top). */
    a: number;
  };
  type Wave = { x: number; y: number; t0: number };

  const DOT_SPACING = 2.1;      // CSS-px between sample points
  const DOT_RADIUS = 0.6;       // CSS-px radius per painted dot
  const REPEL_RADIUS = 64;      // CSS-px influence radius around pointer
  const REPEL_STRENGTH = 14;    // CSS-px max displacement at cursor
  const SPRING = 0.18;          // [0,1] lerp each frame toward target
  const SETTLE_EPS = 0.12;      // CSS-px — considered at-rest below this

  // Click-wave: an expanding ring originating at the click point.
  const WAVE_SPEED = 200;       // CSS-px/s — ripple pace, not shockwave
  const WAVE_WIDTH = 56;        // CSS-px — width of the "active" ring band
  const WAVE_AMPLITUDE = 13;    // CSS-px — max outward push at ring peak
  const WAVE_DURATION = 1500;   // ms — lifetime before wave is discarded

  const canvas = document.querySelector<HTMLCanvasElement>("[data-mark-canvas]");
  const fallback = document.querySelector<HTMLElement>(".mark-fallback");
  if (!canvas) {
    /* nothing to do */
  } else {
    const ctx = canvas.getContext("2d");
    if (!ctx) {
      /* noop */
    } else {
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      let dots: Dot[] = [];
      let waves: Wave[] = [];
      let cssW = 0;
      let cssH = 0;
      let pointerX = -9999;
      let pointerY = -9999;
      let pointerInside = false;
      let rafId: number | null = null;

      // Sample the mark geometry into a dot array. Two passes so the
      // square-frame dots and the diagonal dots can be tagged with
      // different alpha rules. (A single rasterised gradient would
      // fail: sampling alpha in a post-render pass can't tell frame
      // pixels apart from diagonal pixels, and threshold-based
      // sampling would drop the faded top of the diagonal entirely.)
      function sample(size: number): Dot[] {
        const dpr = Math.max(1, window.devicePixelRatio || 1);
        const scale = size / MARK_VIEWBOX;
        const step = DOT_SPACING * dpr;

        function renderAndSample(
          draw: (c: CanvasRenderingContext2D) => void,
          alphaFor: (cssX: number, cssY: number) => number
        ): Dot[] {
          const off = document.createElement("canvas");
          off.width = size * dpr;
          off.height = size * dpr;
          const octx = off.getContext("2d");
          if (!octx) return [];
          octx.scale(dpr, dpr);
          octx.lineJoin = "miter";
          octx.lineCap = "butt";
          octx.strokeStyle = "#000";
          draw(octx);
          const img = octx.getImageData(0, 0, off.width, off.height).data;
          const out: Dot[] = [];
          for (let py = step / 2; py < off.height; py += step) {
            for (let px = step / 2; px < off.width; px += step) {
              const i = (Math.floor(py) * off.width + Math.floor(px)) * 4 + 3;
              if (img[i] > 140) {
                const x = px / dpr;
                const y = py / dpr;
                out.push({ bx: x, by: y, x, y, a: alphaFor(x, y) });
              }
            }
          }
          return out;
        }

        // Pass 1: outer square frame — every sampled dot is fully opaque.
        const frameDots = renderAndSample((c) => {
          c.lineWidth = FRAME.stroke * scale;
          c.strokeRect(
            FRAME.x * scale,
            FRAME.y * scale,
            FRAME.w * scale,
            FRAME.h * scale
          );
        }, () => DIAGONAL_FADE.maxAlpha);

        // Pass 2: diagonal stroke — alpha fades from bottom (maxAlpha)
        // to top (minAlpha) along the viewBox Y axis.
        const topCssY = DIAGONAL_FADE.topY * scale;
        const bottomCssY = DIAGONAL_FADE.bottomY * scale;
        const alphaRange = DIAGONAL_FADE.maxAlpha - DIAGONAL_FADE.minAlpha;
        const diagDots = renderAndSample((c) => {
          c.lineWidth = DIAGONAL.stroke * scale;
          c.beginPath();
          c.moveTo(DIAGONAL.x1 * scale, DIAGONAL.y1 * scale);
          c.lineTo(DIAGONAL.x2 * scale, DIAGONAL.y2 * scale);
          c.stroke();
        }, (_x, cssY) => {
          // 0 at bottom (full), 1 at top (faded).
          const t = (bottomCssY - cssY) / (bottomCssY - topCssY);
          const clamped = Math.min(1, Math.max(0, t));
          return DIAGONAL_FADE.maxAlpha - alphaRange * clamped;
        });

        return frameDots.concat(diagDots);
      }

      function resize() {
        const rect = canvas!.getBoundingClientRect();
        const nextW = Math.round(rect.width);
        const nextH = Math.round(rect.height);
        if (nextW === cssW && nextH === cssH) return;
        cssW = nextW;
        cssH = nextH;
        const dpr = Math.max(1, window.devicePixelRatio || 1);
        canvas!.width = cssW * dpr;
        canvas!.height = cssH * dpr;
        ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
        dots = sample(Math.min(cssW, cssH));
        if (fallback) fallback.style.display = "none";
        draw();
      }

      function draw() {
        ctx!.clearRect(0, 0, cssW, cssH);
        // Dots inherit --ink so the canvas is palette-consistent with
        // the rest of the page. Per-dot alpha is applied via
        // globalAlpha so we don't pay for a new rgba string on each
        // draw. Setting globalAlpha ~600×/frame is ~35k assignments
        // per second — trivial next to the arc/fill ops.
        const ink =
          getComputedStyle(document.documentElement)
            .getPropertyValue("--ink")
            .trim() || "#1b1917";
        ctx!.fillStyle = ink;
        for (const d of dots) {
          ctx!.globalAlpha = d.a;
          ctx!.beginPath();
          ctx!.arc(d.x, d.y, DOT_RADIUS, 0, Math.PI * 2);
          ctx!.fill();
        }
        ctx!.globalAlpha = 1;
      }

      function tick() {
        const now = performance.now();
        // Retire waves past their lifetime.
        if (waves.length) {
          waves = waves.filter((w) => now - w.t0 < WAVE_DURATION);
        }

        let moving = false;
        for (const d of dots) {
          let targetX = d.bx;
          let targetY = d.by;

          // Pointer hover: inward vector push, soft short-range repel.
          if (pointerInside) {
            const dx = pointerX - d.bx;
            const dy = pointerY - d.by;
            const dist = Math.hypot(dx, dy);
            if (dist < REPEL_RADIUS && dist > 0.001) {
              const falloff = 1 - dist / REPEL_RADIUS;
              const push = falloff * falloff * REPEL_STRENGTH;
              targetX -= (dx / dist) * push;
              targetY -= (dy / dist) * push;
            }
          }

          // Click-wave: expanding ring pushes dots radially outward.
          // Each wave contributes additively so rapid clicks layer.
          for (const w of waves) {
            const waveR = ((now - w.t0) / 1000) * WAVE_SPEED;
            const dx = d.bx - w.x;
            const dy = d.by - w.y;
            const dist = Math.hypot(dx, dy);
            const delta = dist - waveR; // <0 inside ring, >0 outside
            const ringRel = Math.abs(delta) / WAVE_WIDTH;
            if (ringRel < 1 && dist > 0.001) {
              // Amplitude: peaks at ring center, fades with age of wave.
              const life = 1 - (now - w.t0) / WAVE_DURATION;
              // Smooth cosine band — softer than linear, reads as a pulse.
              const band = 0.5 * (1 + Math.cos(Math.PI * ringRel));
              const amp = WAVE_AMPLITUDE * band * life;
              targetX += (dx / dist) * amp;
              targetY += (dy / dist) * amp;
            }
          }

          const ndx = (targetX - d.x) * SPRING;
          const ndy = (targetY - d.y) * SPRING;
          d.x += ndx;
          d.y += ndy;
          if (Math.abs(ndx) > SETTLE_EPS || Math.abs(ndy) > SETTLE_EPS) {
            moving = true;
          }
        }
        draw();
        if (moving || pointerInside || waves.length > 0) {
          rafId = requestAnimationFrame(tick);
        } else {
          rafId = null;
        }
      }

      function kick() {
        if (rafId === null) rafId = requestAnimationFrame(tick);
      }

      canvas.addEventListener("pointermove", (e) => {
        const rect = canvas!.getBoundingClientRect();
        pointerX = e.clientX - rect.left;
        pointerY = e.clientY - rect.top;
        pointerInside = true;
        kick();
      });
      canvas.addEventListener("pointerleave", () => {
        pointerInside = false;
        kick();
      });

      // Click / tap → wave. `pointerdown` fires for mouse, touch, and
      // pen, so a single handler covers all input types.
      canvas.addEventListener("pointerdown", (e) => {
        const rect = canvas!.getBoundingClientRect();
        waves.push({
          x: e.clientX - rect.left,
          y: e.clientY - rect.top,
          t0: performance.now(),
        });
        kick();
      });

      const ro = new ResizeObserver(resize);
      ro.observe(canvas);
      resize();

      if (prefersReduced) {
        // Don't run the physics loop. Draw once, leave dots at base.
        draw();
      }
    }
  }
</script>

<style>
  .about {
    display: grid;
    gap: 1.25rem;
  }

  /* Interactive logo-mark canvas. Sized in CSS only; the JS handles
     dpr scaling on the backing store.

     Negative margin-left optically aligns the first painted dot column
     (which sits at viewBox x=5 — i.e. 5/32 of the canvas width) with
     the "Caldis" headline below. Without this pull the mark visually
     indents by the 5/32 inner padding of the SVG artwork. */
  .mark-hero {
    --mark-size: clamp(140px, 18vw, 180px);
    position: relative;
    width: var(--mark-size);
    aspect-ratio: 1 / 1;
    margin-bottom: 0.5rem;
    margin-left: calc(-5 / 32 * var(--mark-size));
    color: var(--ink);
  }

  .mark-canvas {
    width: 100%;
    height: 100%;
    display: block;
    cursor: crosshair;
  }

  .mark-fallback {
    position: absolute;
    inset: 10%;
    width: 80%;
    height: 80%;
    color: inherit;
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3rem);
    font-weight: 460;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 60;
  }

  p {
    max-width: 32rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink);
  }

  .links {
    list-style: none;
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .links a {
    display: inline-flex;
    color: var(--accent);
    transition: color 180ms ease, transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .links a:hover {
    color: var(--accent-strong);
    transform: translateY(-1px);
  }

  .links svg {
    width: 1.125rem;
    height: 1.125rem;
    display: block;
  }
</style>
