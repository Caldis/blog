---
type Project = {
  title: string;
  subtitle?: string;
  year: number;
  live?: string;
  repo?: string;
  /** Optional GitHub star count. Hardcoded snapshot — refresh manually
   *  when re-publishing. Only set on entries where the count is worth
   *  surfacing as social proof; omit otherwise. */
  stars?: number;
  /** Optional longer prose. Renders as a serif body paragraph below
   *  the subtitle. Reserve for entries that warrant more than the
   *  one-line subtitle — pinned/featured work, projects with a story
   *  worth telling. Plain text (no markup); newlines collapse. */
  description?: string;
};

const projects: Project[] = [
  {
    title: "SDFrame",
    subtitle: "软件设计框架精选",
    year: 2026,
    live: "http://sdframe.caldis.me/",
    repo: "https://github.com/Caldis/frameworks",
  },
  {
    title: "Mos",
    subtitle:
      "macOS 下的鼠标体验优化工具, 支持滚动平滑, 按键映射等 (甚至支持 Logitech 设备专有按键)。",
    year: 2018,
    live: "https://mos.caldis.me/",
    repo: "https://github.com/Caldis/Mos",
    stars: 19886,
  },
  {
    title: "Meow",
    subtitle: "大咪的相册",
    year: 2018,
    live: "https://meow.caldis.me/",
    repo: "https://github.com/Caldis/meow",
  },
  {
    title: "Zmage",
    subtitle: "顺滑的 React 图片缩放控件",
    year: 2017,
    live: "https://zmage.caldis.me",
    repo: "https://github.com/Caldis/react-zmage",
    stars: 927,
  },
  {
    title: "GRA",
    subtitle: "GitHub Releases 下载统计",
    year: 2017,
    live: "http://gra.caldis.me",
    repo: "https://github.com/Caldis/github-releases-downloads-analysis",
  },
  {
    title: "Bobcorn",
    subtitle: "图标字体管理器",
    year: 2017,
    live: "https://bobcorn.caldis.me",
    repo: "https://github.com/Caldis/bobcorn",
  },
];

// Compact star formatting. <1k stays exact, ≥1k collapses to one
// decimal "k" (19886 → 19.9k), ≥100k drops the decimal (123456 →
// 123k). Keeps the badge a stable two- to four-character glyph run.
function formatStars(n: number): string {
  if (n < 1000) return String(n);
  const k = n / 1000;
  if (k < 100) return k.toFixed(1).replace(/\.0$/, "") + "k";
  return Math.round(k) + "k";
}
---

<section class="projects">
  <header class="head">
    <h1>Projects</h1>
    <p>Side builds, kept around.</p>
  </header>

  <ol class="index" role="list">
    {projects.map((p) => (
      <li class="entry">
        <span class="year" aria-label={`Year ${p.year}`}>{p.year}</span>
        <div class="body">
          <h2 class="title">{p.title}</h2>
          {p.subtitle && <p class="subtitle">{p.subtitle}</p>}
          {p.description && <p class="description">{p.description}</p>}
          <div class="links">
            {p.live && (
              <a class="link" href={p.live} target="_blank" rel="noopener">
                <span>Live</span>
                <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M3.25 8.75 L8.75 3.25 M4 3.25 H8.75 V8" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            )}
            {p.repo && (
              <a class="link" href={p.repo} target="_blank" rel="noopener">
                <svg class="gh" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
                <span>Repo</span>
                <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M3.25 8.75 L8.75 3.25 M4 3.25 H8.75 V8" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            )}
            {p.stars !== undefined && (
              <span class="meta" aria-label={`${formatStars(p.stars)} stars on GitHub`}>
                <svg class="star-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
                <span>{formatStars(p.stars)}</span>
              </span>
            )}
          </div>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .projects {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .head {
    display: grid;
    gap: 0.5rem;
  }

  h1 {
    font-size: clamp(2.25rem, 5vw, 3rem);
    font-weight: 460;
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-variation-settings: "opsz" 60;
  }

  .head p {
    color: var(--ink-soft);
    font-size: 0.9375rem;
  }

  .index {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .entry {
    display: grid;
    grid-template-columns: minmax(3rem, 3.5rem) 1fr;
    column-gap: 1.5rem;
    align-items: baseline;
  }

  .year {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    line-height: 1;
    color: var(--ink-faint);
    font-variation-settings: "opsz" 30;
    font-feature-settings: "tnum";
    letter-spacing: 0.01em;
    padding-top: 0.25em;
  }

  .body {
    display: grid;
    gap: 0.375rem;
  }

  .title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 460;
    line-height: 1.15;
    letter-spacing: -0.015em;
    font-variation-settings: "opsz" 36;
  }

  .subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--ink-soft);
    line-height: 1.4;
    font-variation-settings: "opsz" 16;
  }

  /* Featured copy — shown only on entries that opt in via `description`.
     Sits between the italic subtitle (label) and the action row (links).
     Heavier than the subtitle (ink not ink-soft, upright not italic) so
     the eye treats it as primary reading content for the entry; capped
     at 36rem so long lines don't outrun the column. */
  .description {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink);
    max-width: 36rem;
    margin-top: 0.125rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.875rem;
  }

  /* Non-interactive metadata badge in the links row (e.g. star count).
     Mirrors `.link`'s typographic scale so it sits in the same lane,
     but uses ink-soft instead of accent so the eye reads it as info,
     not action. tnum keeps digit widths stable across re-renders. */
  .meta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--ink-soft);
    font-feature-settings: "tnum";
    white-space: nowrap;
  }

  .meta .star-icon {
    width: 0.875rem;
    height: 0.875rem;
  }

  .link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--accent);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .link svg {
    width: 0.75rem;
    height: 0.75rem;
    transition: transform 280ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .link svg.gh {
    width: 0.875rem;
    height: 0.875rem;
    margin-right: 0.125rem;
  }

  .link:hover {
    color: var(--accent-strong);
  }

  .link:hover svg:not(.gh) {
    transform: translate(1.5px, -1.5px);
  }

  @media (max-width: 28rem) {
    .entry {
      grid-template-columns: 1fr;
      row-gap: 0.25rem;
    }
    .year {
      padding-top: 0;
      font-size: 0.8125rem;
      font-family: var(--font-sans);
      color: var(--ink-faint);
      font-variation-settings: normal;
      letter-spacing: 0.04em;
    }
  }
</style>
