---
const { currentPath } = Astro.props;

const nav = [
  { name: "Thoughts", href: "/thoughts" },
  { name: "Projects", href: "/projects" },
  { name: "About", href: "/about" },
];

interface Props {
  currentPath: string;
}
---

<header>
  <a class="wordmark" href="/thoughts">Caldis's Blog</a>
  <nav aria-label="Primary">
    {nav.map(({ name, href }, i) => {
      const isActive = currentPath.startsWith(href);
      return (
        <Fragment>
          {i > 0 && <span class="sep" aria-hidden="true">·</span>}
          <a
            href={href}
            data-label={name}
            aria-current={isActive ? "page" : undefined}
            class:list={[{ active: isActive }]}
          >
            <span>{name}</span>
          </a>
        </Fragment>
      );
    })}
    <span class="nav-indicator" aria-hidden="true"></span>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding: clamp(2rem, 5vw, 3rem) 0 clamp(2.5rem, 6vw, 4rem);
    flex-wrap: wrap;
  }

  .wordmark {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 480;
    letter-spacing: -0.012em;
    line-height: 1;
    color: var(--ink);
    font-variation-settings: "opsz" 24;
  }

  nav {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: -0.005em;
    color: var(--ink-soft);
    font-variation-settings: "opsz" 18;
  }

  .nav-indicator {
    position: absolute;
    left: 0;
    bottom: 0.08em;
    height: 1px;
    width: var(--indicator-w, 0);
    transform: translate3d(var(--indicator-x, 0), 0, 0);
    background: currentColor;
    opacity: 0;
    pointer-events: none;
  }

  .nav-indicator.ready {
    opacity: 0.7;
    transition:
      transform 760ms cubic-bezier(0.05, 1.0, 0.34, 1.0),
      width 760ms cubic-bezier(0.05, 1.0, 0.34, 1.0),
      opacity 180ms ease;
  }


  /* Ghost-label technique: each anchor is a grid container with its own
     invisible bold twin (::before) reserving width. The real <span> sits in
     the same cell. Width stays locked to the bold state regardless of
     whether the item is currently active, so weight transitions don't
     shift siblings. */
  nav a {
    position: relative;
    display: inline-grid;
    grid-template-areas: "stack";
    text-decoration: none;
    padding-bottom: 0.22em;
    color: inherit;
    transition: color 180ms ease;
  }

  nav a::before {
    content: attr(data-label);
    grid-area: stack;
    font-weight: 540;
    visibility: hidden;
    pointer-events: none;
  }

  nav a > span {
    grid-area: stack;
    font-weight: 400;
    transition: font-weight 180ms ease;
  }

  nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  nav a:not(.active):hover {
    color: var(--ink);
  }

  nav a:not(.active):hover::after {
    opacity: 0.35;
  }

  nav a.active {
    color: var(--ink);
  }

  nav a.active > span {
    font-weight: 540;
  }

  nav a.active::after {
    display: none;
  }

  .sep {
    color: var(--ink-faint);
    user-select: none;
    font-size: 1rem;
    line-height: 1;
  }
</style>
