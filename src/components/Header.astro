---
const { currentPath } = Astro.props;

const nav = [
  { name: "Thoughts", href: "/thoughts" },
  { name: "Projects", href: "/projects" },
  { name: "Albums", href: "/albums" },
  { name: "About", href: "/about" },
];

interface Props {
  currentPath: string;
}
---

<header>
  <a class="wordmark" href="/thoughts">
    <svg
      class="mark"
      viewBox="0 0 32 32"
      aria-hidden="true"
      focusable="false"
    >
      <defs>
        <linearGradient
          id="caldis-mark-diag"
          gradientUnits="userSpaceOnUse"
          x1="11" y1="22"
          x2="22" y2="11"
        >
          <stop offset="0" stop-color="currentColor" stop-opacity="1"/>
          <stop offset="1" stop-color="currentColor" stop-opacity="0.5"/>
        </linearGradient>
      </defs>
      <rect
        x="5" y="5"
        width="22" height="22"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linejoin="miter"
      />
      <line
        x1="11" y1="22"
        x2="22" y2="11"
        stroke="url(#caldis-mark-diag)"
        stroke-width="3.25"
        stroke-linecap="butt"
      />
    </svg>
    <span class="wordmark-text">Caldis's Blog</span>
  </a>
  <nav aria-label="Primary">
    {nav.map(({ name, href }, i) => {
      const isActive = currentPath.startsWith(href);
      return (
        <Fragment>
          {i > 0 && <span class="sep" aria-hidden="true">·</span>}
          <a
            href={href}
            data-label={name}
            aria-current={isActive ? "page" : undefined}
            class:list={[{ active: isActive }]}
          >
            <span>{name}</span>
          </a>
        </Fragment>
      );
    })}
    <span class="nav-indicator" aria-hidden="true"></span>
  </nav>
</header>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding: clamp(2rem, 5vw, 3rem) 0 clamp(2.5rem, 6vw, 4rem);
    flex-wrap: wrap;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 480;
    letter-spacing: -0.012em;
    line-height: 1;
    color: var(--ink);
    font-variation-settings: "opsz" 24;
  }

  /* Center-aligned on the line box, with a tiny lift toward cap
     center. Serif caps sit slightly above line center, so pure
     `align-items: center` reads as mark sitting a hair low; a small
     negative translateY (~0.05em) aligns mark-center with cap-center
     without lifting it clear of the "C". */
  .wordmark .mark {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    transform: translateY(-0.05em);
  }

  .wordmark-text {
    display: inline-block;
  }

  nav {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: -0.005em;
    color: var(--ink-soft);
    font-variation-settings: "opsz" 18;
  }

  .nav-indicator {
    position: absolute;
    left: 0;
    bottom: 0.08em;
    height: 1px;
    width: var(--indicator-w, 0);
    transform: translate3d(var(--indicator-x, 0), 0, 0);
    background: currentColor;
    opacity: 0;
    pointer-events: none;
  }

  .nav-indicator.ready {
    opacity: 0.7;
    transition:
      transform 760ms cubic-bezier(0.05, 1.0, 0.34, 1.0),
      width 760ms cubic-bezier(0.05, 1.0, 0.34, 1.0),
      opacity 180ms ease;
  }


  /* Ghost-label technique: each anchor is a grid container with its own
     invisible bold twin (::before) reserving width. The real <span> sits in
     the same cell. Width stays locked to the bold state regardless of
     whether the item is currently active, so weight transitions don't
     shift siblings. */
  nav a {
    position: relative;
    display: inline-grid;
    grid-template-areas: "stack";
    text-decoration: none;
    padding-bottom: 0.22em;
    color: inherit;
    transition: color 180ms ease;
  }

  nav a::before {
    content: attr(data-label);
    grid-area: stack;
    font-weight: 540;
    visibility: hidden;
    pointer-events: none;
  }

  nav a > span {
    grid-area: stack;
    font-weight: 400;
    transition: font-weight 180ms ease;
  }

  nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08em;
    height: 1px;
    background: currentColor;
    opacity: 0;
    transition: opacity 180ms ease;
  }

  nav a:not(.active):hover {
    color: var(--ink);
  }

  nav a:not(.active):hover::after {
    opacity: 0.35;
  }

  nav a.active {
    color: var(--ink);
  }

  nav a.active > span {
    font-weight: 540;
  }

  nav a.active::after {
    display: none;
  }

  .sep {
    color: var(--ink-faint);
    user-select: none;
    font-size: 1rem;
    line-height: 1;
  }
</style>
