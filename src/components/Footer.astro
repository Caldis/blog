---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <small class="signature">
    © <time datetime={String(year)}>{year}</time>
    <span class="sep" aria-hidden="true">·</span>
    Caldis
  </small>
  <button type="button" class="to-top" data-to-top aria-label="Back to top">
    <span>Back to top</span>
    <span class="arrow" aria-hidden="true">↑</span>
  </button>
</footer>

<script>
  function scrollToTop() {
    const start = window.scrollY || document.documentElement.scrollTop;
    if (start <= 0) return;
    const duration = Math.min(900, Math.max(380, start * 0.45));
    const startTime = performance.now();
    const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);

    function tick(now: number) {
      const p = Math.min((now - startTime) / duration, 1);
      window.scrollTo(0, start * (1 - easeOutQuart(p)));
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  document.querySelectorAll("[data-to-top]").forEach((btn) => {
    btn.addEventListener("click", scrollToTop);
  });
</script>

<style>
  .site-footer {
    margin-top: clamp(3rem, 7vw, 4.5rem);
    padding: 1.5rem 0 0.25rem;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--ink-faint);
  }

  .signature {
    font-size: inherit;
    font-feature-settings: "tnum";
  }

  .signature .sep {
    margin: 0 0.4em;
    opacity: 0.7;
  }

  .to-top {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font: inherit;
    color: inherit;
    display: inline-flex;
    align-items: baseline;
    gap: 0.45em;
    transition: color 180ms ease;
  }

  .to-top:hover {
    color: var(--ink-soft);
  }

  .to-top .arrow {
    display: inline-block;
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .to-top:hover .arrow {
    transform: translateY(-2px);
  }
</style>
