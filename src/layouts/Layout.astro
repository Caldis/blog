---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const fullTitle = title ? `${title} — Caldis's Blog` : "Caldis's Blog";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/newsreader-var.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/geist-var.woff2"
      crossorigin
    />
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-HGYPWSLD0Y"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-HGYPWSLD0Y");
    </script>
    <script is:inline>
      // Stash the active PageRevealEvent.viewTransition so body scripts
      // (e.g. the panorama-unlock logic in album detail pages) can defer
      // work until the morph completes. Must live in <head> so the
      // listener is bound before pagereveal fires; deferred module
      // scripts in the body miss the event.
      (function () {
        window.__pageRevealTransition = null;
        window.addEventListener("pagereveal", function (e) {
          if (e.viewTransition) {
            window.__pageRevealTransition = e.viewTransition;
          }
        });
      })();
    </script>
  </head>
  <body>
    <Header currentPath={currentPath} />
    <div class="container">
      <main>
        <slot />
      </main>
    </div>

    <script>
      // Detail pages use document scroll. Mirror the SpacesLayout
      // behavior: measure the masthead's current height into
      // --header-height (used by .container's top padding) and toggle
      // [data-scrolled] on the header so its bottom hairline fades in
      // once the page has moved past origin.
      function setHeaderHeight() {
        const h = document.querySelector<HTMLElement>("header");
        if (!h) return;
        document.documentElement.style.setProperty(
          "--header-height",
          `${h.getBoundingClientRect().height}px`
        );
      }
      setHeaderHeight();
      window.addEventListener("resize", setHeaderHeight);
      if (document.fonts?.ready) {
        document.fonts.ready.then(setHeaderHeight);
      }

      // Match the SpacesLayout fix: detail pages scroll the document,
      // so the gutter reservation comes from the natural document
      // scrollbar. innerWidth includes it, documentElement.clientWidth
      // doesn't — diff = scrollbar width. Header consumes via
      // padding-right: var(--scrollbar-w).
      function setScrollbarWidth() {
        const w = window.innerWidth - document.documentElement.clientWidth;
        document.documentElement.style.setProperty(
          "--scrollbar-w",
          `${w}px`
        );
      }
      setScrollbarWidth();
      window.addEventListener("resize", setScrollbarWidth);

      const SCROLL_THRESHOLD = 4;
      const siteHeader = document.querySelector<HTMLElement>(
        "header.site-header"
      );

      function syncHeaderScrolled() {
        if (!siteHeader) return;
        const should = window.scrollY > SCROLL_THRESHOLD;
        if (siteHeader.hasAttribute("data-scrolled") !== should) {
          if (should) siteHeader.setAttribute("data-scrolled", "");
          else siteHeader.removeAttribute("data-scrolled");
        }
      }
      window.addEventListener("scroll", syncHeaderScrolled, { passive: true });
      syncHeaderScrolled();
    </script>
  </body>
</html>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    /*
     * Top padding clears the fixed-overlay masthead. Without this, the
     * article's first element (back link, hero image) would sit
     * underneath the bar at scroll origin. As the user scrolls, the
     * content passes through the bar's translucent backdrop instead of
     * being abruptly clipped.
     */
    padding: calc(var(--header-height, 4.5rem) + 1.25rem) clamp(1.25rem, 4vw, 2rem) 0;
  }

  main {
    padding-bottom: clamp(4rem, 10vw, 8rem);
  }
</style>
